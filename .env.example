# ============================================================
# SoroStream Environment Variables
# ============================================================
# Copy this file to .env.local and fill in the values.
#
#   cp .env.example .env.local
#
# Variables prefixed with NEXT_PUBLIC_ are embedded into the
# browser bundle at build time. Changing them requires a full
# rebuild (next build). Variables without that prefix are only
# available server-side and can be updated without rebuilding.
#
# See docs/DEPLOYMENT.md for the full deployment guide.
# ============================================================


# ------------------------------------------------------------
# REQUIRED — the app will refuse to start if these are missing
# ------------------------------------------------------------

# Stellar network to connect to.
# Valid values: "testnet" | "mainnet"
# Default: "testnet"
# ⚠ Rebuild required when changed (NEXT_PUBLIC_ prefix).
NEXT_PUBLIC_STELLAR_NETWORK=testnet

# On-chain address of the deployed SoroStream contract.
# Obtain this after deploying the contract with the Soroban CLI.
# Example: CDLZFC3SYJYDZT7K67VZ75HPJVIEUVNIXF47ZG2FB2RMQQVU2HHGCN
# ⚠ Rebuild required when changed (NEXT_PUBLIC_ prefix).
NEXT_PUBLIC_CONTRACT_ID=


# ------------------------------------------------------------
# OPTIONAL — sensible defaults are used when not set
# ------------------------------------------------------------

# Soroban JSON-RPC endpoint.
# Defaults to the public Stellar testnet RPC when not set.
# Override for mainnet or a private/dedicated RPC node.
# Examples:
#   testnet  → https://soroban-testnet.stellar.org
#   mainnet  → https://mainnet.stellar.validationcloud.io/v1/<API_KEY>
# ⚠ Rebuild required when changed (NEXT_PUBLIC_ prefix).
NEXT_PUBLIC_RPC_URL=https://soroban-testnet.stellar.org
